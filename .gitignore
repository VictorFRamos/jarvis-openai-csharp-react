## A streamlined .gitignore for modern .NET projects
## including temporary files, build results, and
## files generated by popular .NET tools.

# =========================
# .NET
# =========================

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# NuGet Packages
*.nupkg
*.snupkg

# Others
~$*
*~
CodeCoverage/

# MSBuild Logs
*.binlog

# MSTest
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml


# =========================
# React / Node.js
# =========================

# dependencies
node_modules/

# production build
dist/
build/

# environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# cache
.cache/
.parcel-cache/
.next/
.nuxt/
.svelte-kit/

# coverage
coverage/

# misc
.DS_Store
*.pem

# IDEs
.vscode/
.idea/

# lock files (opcional - escolha 1 padrão no time)
package-lock.json
yarn.lock
pnpm-lock.yaml

# vite
vite.svg

# typescript
*.tsbuildinfo